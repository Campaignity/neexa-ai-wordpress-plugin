#!/bin/bash
# Keeps svn/trunk in sync with every git commit.
# Publishing a release to WP.org is handled separately by release.sh.
set -e

PLUGIN_DIR="$(git rev-parse --show-toplevel)"
SVN_TRUNK="$PLUGIN_DIR/../svn/trunk"

if [ ! -d "$SVN_TRUNK" ]; then
    echo "[svn] svn/trunk not found — skipping sync"
    exit 0
fi

echo "[svn] Syncing trunk..."
rsync -a --delete \
    --exclude-from="$PLUGIN_DIR/.distignore" \
    "$PLUGIN_DIR/" "$SVN_TRUNK/"

svn add --force "$SVN_TRUNK" > /dev/null 2>&1
svn status "$SVN_TRUNK" | grep '^!' | awk '{print $2}' | xargs -r svn delete --force > /dev/null 2>&1

echo "[svn] Trunk synced. Run ./release.sh to publish to WordPress.org."
