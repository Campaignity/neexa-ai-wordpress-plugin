#!/bin/bash
# Syncs the plugin source to svn/trunk after every commit.
# When HEAD carries a git tag, also creates the matching SVN tag and commits.
set -e

PLUGIN_DIR="$(git rev-parse --show-toplevel)"
SVN_DIR="$PLUGIN_DIR/../svn"
SVN_TRUNK="$SVN_DIR/trunk"

if [ ! -d "$SVN_TRUNK" ]; then
    echo "[svn] svn/trunk not found — skipping SVN sync"
    exit 0
fi

echo "[svn] Syncing trunk..."
rsync -a --delete \
    --exclude-from="$PLUGIN_DIR/.distignore" \
    "$PLUGIN_DIR/" "$SVN_TRUNK/"

# Mark new files and remove deleted files in SVN
svn add --force "$SVN_TRUNK" > /dev/null 2>&1
svn status "$SVN_TRUNK" | grep '^!' | awk '{print $2}' | xargs -r svn delete --force > /dev/null 2>&1

# Check if HEAD has a git tag → release
TAG=$(git tag --points-at HEAD | head -n1)
if [ -n "$TAG" ]; then
    SVN_TAG_DIR="$SVN_DIR/tags/$TAG"
    if [ -d "$SVN_TAG_DIR" ]; then
        echo "[svn] Tag $TAG already exists in SVN — skipping tag creation"
    else
        echo "[svn] Creating SVN tag $TAG..."
        svn copy "$SVN_TRUNK" "$SVN_TAG_DIR"
    fi
    svn commit "$SVN_DIR" -m "Release $TAG"
    echo "[svn] Released $TAG"
else
    echo "[svn] Trunk synced. Run 'svn commit ../svn/trunk' to push to WordPress.org."
fi
